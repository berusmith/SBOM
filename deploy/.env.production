# SBOM Platform - 生產環境設定
# 部署後請修改 SECRET_KEY 和 ADMIN_PASSWORD

DATABASE_URL=sqlite:////var/www/sbom/data/sbom.db
UPLOAD_DIR=/var/www/sbom/data/uploads

# 請務必修改以下兩個值
SECRET_KEY=please-change-this-to-a-random-64-char-string
ADMIN_PASSWORD=please-change-this-password

ADMIN_USERNAME=admin
JWT_EXPIRE_HOURS=8
ALLOWED_ORIGIN=http://161.33.130.101
DEBUG=false

# NVD API Key（可選）
NVD_API_KEY=

# SMTP 通知（可選）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
