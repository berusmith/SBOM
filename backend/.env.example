# 複製此檔為 .env 並填入實際值
# cp .env.example .env

# 資料庫（預設 SQLite，不需修改）
DATABASE_URL=sqlite:///./sbom.db

# JWT 密鑰（建議修改為隨機字串）
SECRET_KEY=change-me-in-production

# 管理員帳號密碼
ADMIN_USERNAME=admin
ADMIN_PASSWORD=sbom@2024

# JWT 有效時間（小時）
JWT_EXPIRE_HOURS=8

# SMTP Email 通知（選填）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true

# NVD API Key（選填，無 key 每 30 秒 5 次，有 key 每 30 秒 50 次）
# 申請：https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=
