# 複製此檔為 .env 並填入實際值
# cp .env.example .env

# 資料庫
# 預設 SQLite（開發/單機）：
DATABASE_URL=sqlite:///./sbom.db
# 切換 Postgres（企業部署）：
# DATABASE_URL=postgresql://sbom_user:your_password@localhost:5432/sbom_db

# JWT 密鑰（建議修改為隨機字串）
SECRET_KEY=change-me-in-production

# 管理員帳號密碼
ADMIN_USERNAME=admin
ADMIN_PASSWORD=sbom@2024

# JWT 有效時間（小時）
JWT_EXPIRE_HOURS=8

# SMTP Email 通知（選填）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true

# NVD API Key（選填，無 key 每 30 秒 5 次，有 key 每 30 秒 50 次）
# 申請：https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# GitHub Token（選填，用於 GHSA 情資補強）
# 無 token：60 req/h；有 token：5000 req/h
# 建立：https://github.com/settings/tokens（read-only public 即可）
GITHUB_TOKEN=

# OIDC / SSO（選填，全部留空則停用 SSO）
# Azure AD 範例：
# OIDC_ISSUER=https://login.microsoftonline.com/{tenant-id}/v2.0
# OIDC_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URI=https://sbom.example.com/api/auth/oidc/callback
#
# Google 範例：
# OIDC_ISSUER=https://accounts.google.com
#
# Keycloak 範例：
# OIDC_ISSUER=https://auth.example.com/realms/your-realm
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=
